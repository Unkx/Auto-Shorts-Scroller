{
  "manifest_version": 3,
  "name": "AutoScroller – Shorts & Reels",
  "version": "1.0.0",
  "description": "Automatyczne przewijanie YouTube Shorts, TikTok i Instagram Reels",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://www.tiktok.com/*",
    "*://www.instagram.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/shorts/*",
        "*://www.tiktok.com/*",
        "*://www.instagram.com/reels/*",
        "*://www.instagram.com/reel/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
